{
  "name": "n8n-nodes-openclaw-chat",
  "version": "1.0.7",
  "description": "n8n node to interact with OpenClaw Gateway HTTP API (chat completions, embeddings, models, responses, tools)",
  "keywords": [
    "n8n-community-node-package",
    "openclaw",
    "ai",
    "chat",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/EncryptShawn/n8n-nodes-openclaw-chat",
  "author": {
    "name": "EncryptShawn",
    "email": "shawn@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EncryptShawn/n8n-nodes-openclaw-chat.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/nodes/OpenClaw && cp src/nodes/OpenClaw/*.svg dist/nodes/OpenClaw/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "files": [
    "dist",
    "credentials",
    "nodes"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OpenClawApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/OpenClaw/OpenClawChat.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "n8n-core": "^1.122.18",
    "n8n-workflow": "^2.13.1",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "^2.13.1"
  },
  "dependencies": {
    "lodash": "^4.18.1"
  }
}